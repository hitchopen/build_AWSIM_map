# PointCloud Data files often exceed GitHub's 100 MB hard limit (the TM99
# track map's pointcloud_map.pcd is ~855 MB), so route them through Git LFS.
# Run `git lfs install` once per machine before cloning or pushing.
*.pcd filter=lfs diff=lfs merge=lfs -text

# Wavefront OBJ mesh files: ground.obj is ~140 MB on TM99 and exceeds the
# 100 MB hard limit too. The wall meshes are smaller but route them through
# LFS as well so the meshes/ directory is consistently LFS-managed.
*.obj filter=lfs diff=lfs merge=lfs -text
